{
  "name": "retentio-webapp",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "generate:md": "node scripts/generate-index.mjs",
    "dev": "npm run generate:md && next dev",
    "build": "npm run generate:md && next build",
    "start": "npm run generate:md && next start",
    "lint": "eslint --fix .",
    "lint:ci": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,md,mdx,json,jsonc,yml,yaml}": "eslint --fix"
  },
  "dependencies": {
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/env": "^16.2.7",
    "@next/mdx": "^16.2.2",
    "@react-stately/data": "^3.16.0",
    "@types/mdx": "^2.0.13",
    "ag-grid-community": "35.2.1",
    "ag-grid-react": "^35.2.1",
    "clsx": "^2.1.1",
    "fast-glob": "^3.3.3",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "gray-matter": "^4.0.3",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "throttle-debounce": "^5.0.2",
    "use-debounce": "^10.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
